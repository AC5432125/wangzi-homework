{
  "version": 2,
  "name": "homework-grader",
  "builds": [
    {
      "src": "api/grade.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/grade",
      "dest": "/api/grade.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}